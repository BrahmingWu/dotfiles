{
    "layer": "top",
    "position": "top",
    "height": 34,
    "spacing": 4,
    "exclusive": true,
    // жЁЎеқ—еёғеұҖ
    "modules-left": [
        "niri/window"
    ],
    "modules-center": [
        "niri/workspaces"
    ],
    "modules-right": [
        "tray",
        "wireplumber",
        "backlight",
        // "network",
        "battery",
        "clock"
    ],

    // --- жЁЎеқ—иҜҰз»Ҷй…ҚзҪ® ---

    "niri/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "active": "пҶ’",
            "default": "п„‘"
        }
    },

    "niri/window": {
        "format": " {title} ",
        "separate-outputs": true,
        "max-length": 50
    },

    "clock": {
        "format": "пҖ— {:%H:%M  пҒі %m-%d}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>"
    },

    "wireplumber": {
        "format": "{icon}  {volume}%",
        "format-muted": "пҖҰ Muted",
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "format-icons": ["пҖҰ", "пҖ§", "пҖЁ"]
    },
    "backlight": {
      "device": "intel_backlight",
      "format": "{icon} {percent}%",
      "format-icons": ["у°ғһ", "у°ғҹ", "у°ғ "],
      "on-scroll-up": "brightnessctl set +5%",
      "on-scroll-down": "brightnessctl set 5%-"
    },

    "network": {
        "format-wifi": "пҮ«  {essid}",
        "format-ethernet": "у°ҲҖ Wired",
        "format-disconnected": "вҡ  Disconnected",
        "tooltip-format": "{ipaddr}/{cidr}",
        "on-click": "ghostty --title='WiFi-Manager' -e nmtui"
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "у°Ӯ„ {capacity}%",
        "format-plugged": "пҮҰ {capacity}%",
        "format-icons": ["пү„", "пүғ", "пүӮ", "пүҒ", "пүҖ"]
    },

    "tray": {
        "icon-size": 18,
        "spacing": 10
    }
}
