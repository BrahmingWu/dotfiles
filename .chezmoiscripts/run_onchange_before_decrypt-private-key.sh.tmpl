#!/bin/sh
set -e

KEY_DIR="${HOME}/Documents/App"
KEY_FILE="${KEY_DIR}/chezmoiKey.key"
ENC_KEY_FILE="{{ .chezmoi.sourceDir }}/chezmoiKey.key.age"

if [ ! -f "${KEY_FILE}" ]; then
  mkdir -p "${KEY_DIR}"
  if ! chezmoi age decrypt --output "${KEY_FILE}" --passphrase "${ENC_KEY_FILE}"; then
    echo "ERROR: Failed to decrypt age key" >&2
    rm -f "${KEY_FILE}"
    exit 1
  fi
  chmod 600 "${KEY_FILE}"
  echo "Age key restored to ${KEY_FILE}"
fi
