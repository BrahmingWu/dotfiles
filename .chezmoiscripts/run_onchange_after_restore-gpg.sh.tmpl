#!/bin/sh
set -e
# version: 2

log_skip() { echo "GPG restore: skipped - $*"; }

command -v gpg >/dev/null 2>&1 || { log_skip "gpg not installed"; exit 1; }

# Check for actual secret key output (keyboxd returns 0 even with no keys)
if gpg --list-secret-keys 2>/dev/null | grep -q "^sec"; then
  log_skip "secret keys already exist"
  exit 0
fi

GPG_BACKUP_DIR="{{ .chezmoi.sourceDir }}/ignorefiles/gpg"
KEY_FILE="${HOME}/Documents/App/chezmoiKey.key"

if [ ! -d "${GPG_BACKUP_DIR}" ]; then
  log_skip "backup dir not found"
  exit 0
fi

if [ ! -f "${GPG_BACKUP_DIR}/private.asc.age" ]; then
  log_skip "encrypted private key not found"
  exit 0
fi

command -v age >/dev/null 2>&1 || { log_skip "age not installed"; exit 1; }

if [ ! -f "${KEY_FILE}" ]; then
  log_skip "age key not found at ${KEY_FILE}"
  exit 1
fi

GPG_IMPORT_DIR=$(mktemp -d)
trap 'rm -rf "${GPG_IMPORT_DIR}"' EXIT

age -d -i "${KEY_FILE}" -o "${GPG_IMPORT_DIR}/public.asc" "${GPG_BACKUP_DIR}/public.asc.age"
age -d -i "${KEY_FILE}" -o "${GPG_IMPORT_DIR}/private.asc" "${GPG_BACKUP_DIR}/private.asc.age"

if [ -f "${GPG_BACKUP_DIR}/ownertrust.txt.age" ]; then
  age -d -i "${KEY_FILE}" -o "${GPG_IMPORT_DIR}/ownertrust.txt" "${GPG_BACKUP_DIR}/ownertrust.txt.age"
fi

gpg --import "${GPG_IMPORT_DIR}/public.asc"
gpg --import "${GPG_IMPORT_DIR}/private.asc"

if [ -f "${GPG_IMPORT_DIR}/ownertrust.txt" ]; then
  gpg --import-ownertrust "${GPG_IMPORT_DIR}/ownertrust.txt"
fi

echo "GPG keys restored successfully."